# ==============================================================================
# RECALL - ROOT ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================
# Copy this file to '.env' (for production/staging) or '.env.local' (for local dev).
# Do NOT commit filled in .env files to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Neon PostgreSQL connection string (must include ?sslmode=require)
DATABASE_URL="postgresql://username:password@ep-host-name-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ------------------------------------------------------------------------------
# 2. TELEGRAM BOT CONFIGURATION
# ------------------------------------------------------------------------------
# Telegram Bot API token obtained from @BotFather (keep secret)
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklmnoPQRstuvwxyZ123456789"
# Username of the Telegram bot (without the '@', e.g. RecallMemoryBot)
VITE_BOT_USERNAME="RecallMemoryBot"

# ------------------------------------------------------------------------------
# 3. SECURITY & CRYPTOGRAPHY
# ------------------------------------------------------------------------------
# Fernet symmetric key (generate with cryptography.fernet.Fernet.generate_key().decode())
FERNET_KEY="yF4P-W965hF17Bq_Q7g_oG5l8S631P9_9z-d8v7d8sA="
# Secret key for JWT signing (generate using a secure random hex string, minimum 32 chars)
JWT_SECRET="8a7b6c5d4e3f2a1b0c9d8e7f6a5b4c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b"
# Telegram incoming webhook secret token
TELEGRAM_WEBHOOK_SECRET="some_telegram_webhook_secret_here"
# Internal shared secret for API validation (e.g. scripts/benchmarks)
INTERNAL_API_KEY="dev_internal_api_key"
# Hash secret/salt for security logs and observability
LOG_HASH_SECRET="default_observability_secret_salt"

# ------------------------------------------------------------------------------
# 4. REDIS CONFIGURATION (UPSTASH)
# ------------------------------------------------------------------------------
# Upstash Redis REST URL endpoint
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# ------------------------------------------------------------------------------
# 5. AI PROVIDERS & API KEYS
# ------------------------------------------------------------------------------
# Groq Cloud API Key
GROQ_API_KEY="gsk_mock_groq_api_key_for_dev_only_12345"
# Google Gemini (Google AI Studio) API Key
GEMINI_API_KEY="AIzaSyMockGeminiKeyForDevOnly12345"
# NVIDIA API Key
NVIDIA_API_KEY="nvapi-mock-nvidia-key-for-dev-only-12345"
# OpenRouter API Key (Optional)
OPENROUTER_API_KEY=""
# Cerebras API Key (Optional)
CEREBRAS_API_KEY=""
# Hugging Face token (For rate-limit-free local transformer models)
HF_TOKEN=""

# ------------------------------------------------------------------------------
# 6. SERVERLESS GPU (MODAL) CONFIGURATION
# ------------------------------------------------------------------------------
# Modal token to execute serverless GPU applications
MODAL_API_TOKEN=""
# Individual endpoint URLs for Modal services
MODAL_SUMMARY_URL=""
# Modal transcription service endpoint URL
MODAL_TRANSCRIBE_URL=""
# Modal tag generation service endpoint URL
MODAL_TAGS_URL=""
# Modal RAG querying service endpoint URL
MODAL_RAG_URL=""
# Modal embedding generation service endpoint URL
MODAL_EMBED_URL=""

# ------------------------------------------------------------------------------
# 7. GOOGLE OAUTH CONFIGURATION (drive.file scope)
# ------------------------------------------------------------------------------
# Google Cloud Console client ID for OAuth
GOOGLE_CLIENT_ID="123456789-mockgoogleid.apps.googleusercontent.com"
# Google Cloud Console client secret for OAuth
GOOGLE_CLIENT_SECRET="GOCSPX-mockgooglesecret12345"
# OAuth callback URL registered in GCP (e.g., http://localhost:8000/auth/google/callback)
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"

# ------------------------------------------------------------------------------
# 8. APP DEPLOYMENT CONFIGURATION
# ------------------------------------------------------------------------------
# Environment mode (development / production / test)
ENV="development"
# Base URL where the React frontend dashboard is hosted
WEBSITE_URL="http://localhost:5173"
# Base API URL of the FastAPI backend (for frontend references)
VITE_API_URL="http://localhost:8000"
# Toggle worker running inline inside backend process (True/False)
RUN_WORKER_INLINE="True"
# Disable or enable local loopback private IP connections (True/False)
ALLOW_PRIVATE_IPS="False"

# ------------------------------------------------------------------------------
# 9. PERFORMANCE & SEARCH TUNING
# ------------------------------------------------------------------------------
# OCR Provider (nvidia / local / remote / gemini)
OCR_PROVIDER="nvidia"
# Sentence Splitter (spacy / regex / remote)
SENTENCE_SPLITTER="spacy"
# Embedding Provider (local / remote)
EMBEDDING_PROVIDER="local"
# Remote AI server endpoint (e.g. if hosting embeddings/cross-encoders on Azure VM)
REMOTE_AI_URL="http://127.0.0.1:8001"
# Reranking toggler (True/False)
ENABLE_RERANKING="True"
# Preload reranking model on startup (True/False)
RERANK_PRELOAD_ON_STARTUP="True"
# Reranker Provider (local / remote)
RERANKER_PROVIDER="local"
# Reranker model
RERANKER_MODEL="Xenova/ms-marco-MiniLM-L-6-v2"
# Number of candidates retrieved for hybrid search
RERANK_CANDIDATES="20"
# Number of top results returned after reranking
RERANK_TOP_N="5"

# ------------------------------------------------------------------------------
# 10. OBSERVABILITY & SENTRY (OPTIONAL)
# ------------------------------------------------------------------------------
# Sentry DSN URL
SENTRY_DSN=""
# Sentry Environment name
SENTRY_ENV="development"
# Sentry traces sample rate (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE="0.1"
# Enable JSON format for logs (True/False)
LOG_JSON="True"
# Logging sample rate (0.0 to 1.0)
LOG_SAMPLE_RATE="1.0"

# ------------------------------------------------------------------------------
# 11. MEDIA PARSING & DOWNLOADING (OPTIONAL)
# ------------------------------------------------------------------------------
# Cobalt API endpoint for Reel downloads
COBALT_API_URL=""
# Optional: API key for Cobalt
COBALT_API_KEY=""
# Instagram cookies encoded in base64 to bypass rate limits
IG_COOKIES_B64=""
# Browser used to extract local cookies
BROWSER_FOR_COOKIES=""
