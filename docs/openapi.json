  "components": {
    "schemas": {
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Programmatic error code."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable error description."
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "title": "ErrorResponse"
      },
      "GraphEdge": {
        "properties": {
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Source node ID."
          },
          "target": {
            "type": "string",
            "title": "Target",
            "description": "Target node ID."
          },
          "weight": {
            "type": "number",
            "title": "Weight",
            "description": "Edge weight representing similarity."
          }
        },
        "type": "object",
        "required": [
          "source",
          "target",
          "weight"
        ],
        "title": "GraphEdge"
      },
      "GraphNode": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Node ID (e.g. 'item_12' or 'hub_5')."
          },
          "type": {
            "type": "string",
            "title": "Type",
            "description": "Node type: 'orbital', 'hub', or 'pulse'."
          },
          "label": {
            "type": "string",
            "title": "Label",
            "description": "Node display label."
          },
          "x": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "X",
            "description": "Optional X coordinate for Mind Map layout."
          },
          "y": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Y",
            "description": "Optional Y coordinate for Mind Map layout."
          },
          "item_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Item Id",
            "description": "Direct item ID if this node represents a saved item."
          }
        },
        "type": "object",
        "required": [
          "id",
          "type",
          "label"
        ],
        "title": "GraphNode"
      },
      "GraphResponse": {
        "properties": {
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/GraphNode"
            },
            "type": "array",
            "title": "Nodes",
            "description": "All items and semantic hub nodes."
          },
          "edges": {
            "items": {
              "$ref": "#/components/schemas/GraphEdge"
            },
            "type": "array",
            "title": "Edges",
            "description": "Connections between nodes representing similarity."
          }
        },
        "type": "object",
        "required": [
          "nodes",
          "edges"
        ],
        "title": "GraphResponse"
      },
      "HTTPValidationError": {
        "properties": {
